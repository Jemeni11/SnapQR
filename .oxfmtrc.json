{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 140,
  "singleQuote": false,
  "bracketSpacing": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "quoteProps": "consistent",
  "bracketSameLine": false,
  "sortTailwindcss": {
    "stylesheet": "./src/globals.css",
    "functions": ["cn"]
  },
  "sortImports": {
    "customGroups": [
      {
        "groupName": "react",
        "elementNamePattern": ["react"]
      }
    ],
    "groups": [
      "react",
      ["value-builtin", "value-external"],
      "value-internal",
      ["value-parent", "value-sibling", "value-index"],
      "type-import",
      "style",
      "unknown"
    ],
    "newlinesBetween": true
  },
  "importOrder": [
    "^react$",
    "",
    "^react-native$",
    "",
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@(.*)$",
    "",
    "^[./]",
    "^(?!.*[.]css$)[./].*$",
    ".css$"
  ],
  "sortPackageJson": true,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "dist-ssr",
    "vite.config.js.timestamp-*",
    "vite.config.ts.timestamp-*",
    ".vite/",
    ".env",
    ".env.*",
    "!.env.example",
    "*.tsbuildinfo",
    "logs",
    "*.log",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    "pnpm-debug.log*",
    "lerna-debug.log*",
    "bun-debug.log*",
    ".npm",
    ".eslintcache",
    ".stylelintcache",
    ".prettier-cache",
    ".node_repl_history",
    ".pnpm-store",
    ".pnp",
    ".pnp.*",
    ".yarn/*",
    "!.yarn/patches",
    "!.yarn/plugins",
    "!.yarn/releases",
    "!.yarn/sdks",
    "!.yarn/versions",
    ".DS_Store",
    "__MACOSX/",
    ".husky/_",
    ".vscode/*",
    "!.vscode/extensions.json",
    "!.vscode/settings.json",
    "!.vscode/tasks.json",
    "!.vscode/launch.json",
    "*.code-workspace",
    ".idea/",
    ".zed/",
    "package-lock.json",
    "pnpm-lock.yaml",
    "routeTree.gen.ts"
  ]
}
